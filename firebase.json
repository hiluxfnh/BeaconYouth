{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "site": "beaconyouth",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {"source": "**/*.@(html|css|js)", "headers": [{"key": "Cache-Control", "value": "public, max-age=600"}]}
    ]
  },
  "emulators": {
    "hosting": {
      "port": 5000
    },
    "firestore": {
      "port": 8080
    },
    "ui": {
      "enabled": true,
      "port": 4000
    }
  }
}
